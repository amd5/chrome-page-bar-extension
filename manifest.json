{
  "manifest_version": 3,
  "name": "Page Info Bottom Bar",
  "version": "0.1.1",
  "description": "Show page load time, IP, city, server, runtime, and CDN status in a bottom bar.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://cloudflare-dns.com/*",
    "https://dns.google/*",
    "https://ip.22kf.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ],
      "run_at": "document_start"
    }
  ]
}
